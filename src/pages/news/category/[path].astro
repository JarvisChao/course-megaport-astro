---
import NewsList from '@/components/News/List.astro';
import NewsLayout from '@/layouts/NewsLayout.astro';
import { getCollection } from 'astro:content';

// getStaticPaths 用來定義 router
export async function getStaticPaths() {
  const entries = (await getCollection('news')).sort((a, b) =>
    b.data.publishDate.localeCompare(a.data.publishDate),
  );
  const newsCategories = (await getCollection('newsCategories')).sort(
    (a, b) => a.data.order - b.data.order,
  );

  return newsCategories
    .filter(({ id }) => id !== 'all')
    .map((category) => {
      let list = entries.filter((entry) => entry.data.category === category.id);

      if (category.id === 'latest') list = entries.slice(0, 4);
      if (category.id === 'others') {
        // 篩出沒有設定分類的
        list = entries.filter((entry) => !entry.data.category);
      }

      return {
        // params 設定路徑，將檔名的 [path].astro 帶入 md 的檔名作為路徑
        params: { path: category.id },
        props: { currentCategory: category.data, list },
      };
    });
}

const { currentCategory, list } = Astro.props;
---

<NewsLayout currentCategory={currentCategory}>
  <NewsList list={list} />
</NewsLayout>
