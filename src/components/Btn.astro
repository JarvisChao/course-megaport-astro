---
interface Props {
  href?: string;
  target?: string;
  align?: string;
  size?: string;
  class?: string;
}

const {
  href = '##',
  target,
  align = '',
  size = '',
  class: className = '',
  ...attrs
} = Astro.props;
---

<div
  class:list={[
    'o-btn',
    size && `--size-${size}`,
    align && `--align-${align}`,
    className,
  ]}
  {...attrs}
>
  <a href={href} target={target} class="o-btn__link"><slot /></a>
</div>

<style lang="scss">
  .o-btn {
    width: 100%;
    &.--align-right {
      display: flex;
      justify-content: flex-end;
    }
    &.--full &__link {
      display: block;
    }
    &__link {
      display: inline-block;
      padding: var(--spacing-1) var(--spacing-16);
      border-radius: 999px;
      border: 1px solid var(--color-secondary);
      font-family: var(--font-en);
      font-weight: 700;
      color: var(--color-secondary);
      text-align: center;
      transition: 0.3s;
      &:hover {
        background-color: var(--color-secondary);
        color: var(--color-black);
      }
    }
  }
</style>
