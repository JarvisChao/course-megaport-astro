---
import Blockade from '@/components/Blockade.astro';

interface Props {
  blockade?: boolean;
  blockadeText?: string;
}

const { blockade = false, blockadeText } = Astro.props;
---

<div class="l-hero-inner" data-aos="fade-down">
  {blockade && <Blockade text={blockadeText} class="l-hero-inner__blockade" />}
  <slot />
</div>

<style lang="scss">
  .l-hero-inner {
    display: flex;
    justify-content: center;
    align-items: center;
    height: 40vh;
    background-image: url('/course-megaport/img/footer/bg.jpg');
    background-size: cover;
    background-position: center center;

    @include media(max-2xl) {
      margin-top: rem(85);
    }

    @include media(max-sm) {
      margin-top: rem(55);
    }

    &::after {
      content: '';
      display: block;
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      background-color: var(--color-primary);
      mix-blend-mode: multiply;
    }
  }

  :global(.c-blockade.l-hero-inner__blockade) {
    top: auto;
    bottom: -30%;

    @include media(max-2xl) {
      bottom: -20%;
    }

    @include media(max-ipad-portrait) {
      bottom: 10%;
    }

    @include media(max-sm) {
      bottom: -20%;
    }
  }
</style>
