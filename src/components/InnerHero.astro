---
import Blockade from '@/components/Blockade.astro';

interface Props {
  title?: string;
  blockade?: boolean;
  blockadeText?: string;
}

const { title, blockade = false, blockadeText } = Astro.props;
const basePath = import.meta.env.BASE_URL;
const heroBgImage = `${basePath}/img/footer/bg.jpg`;
---

<div class="l-hero-inner" data-aos="fade-down">
  <img src={heroBgImage} alt="" class="u-object-fit --abs" aria-hidden="true" />
  {blockade && <Blockade text={blockadeText} class="l-hero-inner__blockade" />}
  <div class="z-1">
    {title && <h2 class="text-3xl font-900 text-primary">{title}</h2>}
    <slot />
  </div>
</div>

<style lang="scss">
  .l-hero-inner {
    display: flex;
    justify-content: center;
    align-items: center;
    height: 40vh;
    overflow: hidden;

    &::after {
      content: '';
      display: block;
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      background-color: var(--color-primary);
      mix-blend-mode: multiply;
    }
  }

  :global(.c-blockade.l-hero-inner__blockade) {
    top: auto;
    bottom: -30%;

    @include media(max-2xl) {
      bottom: -20%;
    }

    @include media(max-ipad-portrait) {
      bottom: 10%;
    }

    @include media(max-sm) {
      bottom: -20%;
    }
  }
</style>
